import { useState, useEffect, useRef } from "react";

const SYSTEM_PROMPT = `You are Bookie the Bookmaker, a technical textbook author writing a chapter called "Hallucination — When Plausibility Beats Truth" for the book "Design of Agentic Systems with Case Studies."

Your job is to write publication-quality textbook prose. You write in this exact order when asked:
1. The Scenario — one concrete, vivid, specific situation where hallucination causes a real problem. NOT abstract. A real person, a real task, a real failure.
2. The Mechanism — the architectural concept itself, built from the scenario. Why next-token prediction makes plausibility and truth orthogonal objectives.
3. The Design Decision — the Fact Check List Pattern as an architectural layer. What it is, how it works, why it exists.
4. The Failure Case — what breaks when the Fact Check List Pattern is absent or bypassed.
5. The Exercise — one modification the reader can make that triggers the failure.

Rules:
- Never use jargon before intuition. Always explain the concept before naming it.
- Every architectural claim must have a mechanism. Not just a description.
- Write for a graduate student who is smart but has never seen this material before.
- Use the Feynman Standard: if you cannot explain it simply, you do not understand it well enough.
- Keep prose tight. No filler sentences.
- When writing The Scenario, make it feel like a story. Specific names, specific tasks, specific failure.`;

const sections = [
  { key: "scenario", label: "The Scenario", prompt: "Write Section 1: The Scenario. One concrete, vivid story — a specific person doing a specific task, where hallucination causes a real, observable failure. Make it feel real. 3-4 paragraphs. End with a question the reader is now asking: 'Why did that happen?'" },
  { key: "mechanism", label: "The Mechanism", prompt: "Write Section 2: The Mechanism. Build directly from the scenario. Explain why next-token prediction makes plausibility and truth orthogonal objectives. Use the scenario as your anchor. Explain the architectural reason hallucination is inevitable — not a bug, not a flaw, but a structural property of how these models are trained. 4-5 paragraphs. No jargon before intuition." },
  { key: "design", label: "The Design Decision", prompt: "Write Section 3: The Design Decision. Introduce the Fact Check List Pattern as an architectural layer. Explain what it is, how it works structurally, and why it exists as an architectural solution rather than a prompting trick. Be specific about the components: what generates the claim, what verifies it, what halts the pipeline if verification fails. 4-5 paragraphs." },
  { key: "failure", label: "The Failure Case", prompt: "Write Section 4: The Failure Case. Describe what breaks when the Fact Check List Pattern is absent or deliberately bypassed. Be mechanistically specific — trace the exact causal chain from missing verification layer to observable failure. This is not a risk description. This is a mechanism description. 3-4 paragraphs." },
  { key: "exercise", label: "The Exercise", prompt: "Write Section 5: The Exercise. Give the reader one specific modification they can make to a pipeline that will reliably trigger the hallucination failure. Be precise: what to change, what prompt to run, what failure to observe. End with one open question the chapter did not fully resolve." },
];

export default function App() {
  const [content, setContent] = useState({});
  const [loading, setLoading] = useState({});
  const [activeSection, setActiveSection] = useState(null);
  const [history, setHistory] = useState([]);
  const [view, setView] = useState("build"); // "build" or "preview"
  const bottomRef = useRef(null);

  const generateSection = async (section) => {
    setLoading(prev => ({ ...prev, [section.key]: true }));
    setActiveSection(section.key);

    const messages = [
      ...history,
      { role: "user", content: section.prompt }
    ];

    try {
      const response = await fetch("https://api.anthropic.com/v1/messages", {
        method: "POST",
        headers: { "Content-Type": "application/json" },
        body: JSON.stringify({
          model: "claude-sonnet-4-20250514",
          max_tokens: 1000,
          system: SYSTEM_PROMPT,
          messages,
        }),
      });

      const data = await response.json();
      const text = data.content.map(b => b.text || "").join("");

      setContent(prev => ({ ...prev, [section.key]: text }));
      setHistory(prev => [
        ...prev,
        { role: "user", content: section.prompt },
        { role: "assistant", content: text }
      ]);
    } catch (e) {
      setContent(prev => ({ ...prev, [section.key]: "Error generating section. Please try again." }));
    }

    setLoading(prev => ({ ...prev, [section.key]: false }));
    setActiveSection(null);
  };

  const allDone = sections.every(s => content[s.key]);

  return (
    <div style={{ fontFamily: "'Georgia', serif", maxWidth: 860, margin: "0 auto", padding: "2rem 1.5rem", background: "#fdfcf9", minHeight: "100vh" }}>
      <div style={{ borderBottom: "2px solid #1a1a2e", paddingBottom: "1rem", marginBottom: "2rem" }}>
        <div style={{ fontSize: 11, letterSpacing: 2, color: "#666", textTransform: "uppercase", marginBottom: 6 }}>Design of Agentic Systems — Chapter 2</div>
        <h1 style={{ fontSize: 26, fontWeight: 700, color: "#1a1a2e", margin: 0, lineHeight: 1.3 }}>Hallucination: When Plausibility Beats Truth</h1>
        <div style={{ fontSize: 13, color: "#888", marginTop: 8 }}>AI-powered chapter builder · Bookie the Bookmaker</div>
      </div>

      <div style={{ display: "flex", gap: 8, marginBottom: 24 }}>
        {["build", "preview"].map(v => (
          <button key={v} onClick={() => setView(v)} style={{
            padding: "6px 18px", borderRadius: 4, border: "1px solid #1a1a2e",
            background: view === v ? "#1a1a2e" : "transparent",
            color: view === v ? "#fff" : "#1a1a2e",
            cursor: "pointer", fontSize: 13, fontFamily: "Georgia, serif"
          }}>
            {v === "build" ? "Build Mode" : "Preview Chapter"}
          </button>
        ))}
      </div>

      {view === "build" && (
        <div>
          {sections.map((section, i) => {
            const done = !!content[section.key];
            const isLoading = loading[section.key];
            const prevDone = i === 0 || !!content[sections[i - 1].key];

            return (
              <div key={section.key} style={{
                marginBottom: 20, border: "1px solid",
                borderColor: done ? "#2d6a4f" : "#ddd",
                borderRadius: 8, overflow: "hidden",
                opacity: prevDone ? 1 : 0.5
              }}>
                <div style={{
                  display: "flex", alignItems: "center", justifyContent: "space-between",
                  padding: "12px 16px",
                  background: done ? "#f0faf4" : "#f9f9f9",
                }}>
                  <div style={{ display: "flex", alignItems: "center", gap: 10 }}>
                    <span style={{
                      width: 24, height: 24, borderRadius: "50%",
                      background: done ? "#2d6a4f" : "#ddd",
                      color: "#fff", display: "flex", alignItems: "center", justifyContent: "center",
                      fontSize: 12, fontWeight: 700, fontFamily: "sans-serif"
                    }}>{done ? "✓" : i + 1}</span>
                    <span style={{ fontWeight: 600, fontSize: 15, color: "#1a1a2e" }}>{section.label}</span>
                  </div>
                  <button
                    disabled={!prevDone || isLoading}
                    onClick={() => generateSection(section)}
                    style={{
                      padding: "6px 16px", borderRadius: 4,
                      background: isLoading ? "#888" : done ? "#1a6b3c" : "#1a1a2e",
                      color: "#fff", border: "none", cursor: prevDone && !isLoading ? "pointer" : "not-allowed",
                      fontSize: 13, fontFamily: "sans-serif"
                    }}
                  >
                    {isLoading ? "Writing..." : done ? "Regenerate" : "Generate"}
                  </button>
                </div>

                {done && (
                  <div style={{ padding: "16px 20px", borderTop: "1px solid #e8f5ee", background: "#fff" }}>
                    <p style={{ margin: 0, fontSize: 14.5, lineHeight: 1.8, color: "#222", whiteSpace: "pre-wrap" }}>{content[section.key]}</p>
                  </div>
                )}

                {isLoading && (
                  <div style={{ padding: "16px 20px", borderTop: "1px solid #eee", background: "#fff" }}>
                    <div style={{ display: "flex", alignItems: "center", gap: 8, color: "#888", fontSize: 13, fontFamily: "sans-serif" }}>
                      <span style={{ animation: "spin 1s linear infinite", display: "inline-block" }}>⟳</span>
                      Bookie is writing...
                    </div>
                  </div>
                )}
              </div>
            );
          })}

          {allDone && (
            <div style={{ marginTop: 24, padding: 16, background: "#fff8e1", border: "1px solid #f0c040", borderRadius: 8, fontSize: 13, fontFamily: "sans-serif" }}>
              <strong>✅ All sections generated.</strong> Switch to <strong>Preview Chapter</strong> to see the full draft. Next step: copy it into Eddy the Editor for audit.
            </div>
          )}
        </div>
      )}

      {view === "preview" && (
        <div style={{ lineHeight: 1.9, fontSize: 15.5, color: "#1a1a1a" }}>
          {sections.map(section => (
            content[section.key] ? (
              <div key={section.key} style={{ marginBottom: 40 }}>
                <h2 style={{ fontSize: 18, fontWeight: 700, color: "#1a1a2e", borderBottom: "1px solid #eee", paddingBottom: 8, marginBottom: 16 }}>{section.label}</h2>
                <p style={{ margin: 0, whiteSpace: "pre-wrap" }}>{content[section.key]}</p>
              </div>
            ) : (
              <div key={section.key} style={{ marginBottom: 40, padding: 20, background: "#f5f5f5", borderRadius: 8, color: "#999", fontFamily: "sans-serif", fontSize: 13 }}>
                [{section.label} — not yet generated]
              </div>
            )
          ))}
        </div>
      )}

      <style>{`@keyframes spin { from { transform: rotate(0deg); } to { transform: rotate(360deg); } }`}</style>
    </div>
  );
}
